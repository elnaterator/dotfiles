#!/usr/bin/env bash
# Interactive git branch deletion tool
# Allows multi-selection of local and remote branches for deletion

set -euo pipefail

saved_stty=""
cursor=0
selected_count=0
branches=()
branch_types=()
branch_names=()
selected_flags=()

cleanup_terminal() {
    if [ -n "$saved_stty" ]; then
        stty "$saved_stty"
    fi
    tput cnorm 2>/dev/null || true
}

draw_menu() {
    local total_lines
    local visible_lines
    local start
    local end
    local i
    local prefix
    local pointer

    total_lines=$(tput lines 2>/dev/null || echo 24)
    visible_lines=$((total_lines - 7))
    if [ "$visible_lines" -lt 5 ]; then
        visible_lines=5
    fi

    start=0
    if [ "$cursor" -ge "$visible_lines" ]; then
        start=$((cursor - visible_lines + 1))
    fi

    end=$((start + visible_lines - 1))
    if [ "$end" -ge "${#branches[@]}" ]; then
        end=$((${#branches[@]} - 1))
    fi

    printf '\033[H\033[2J'
    echo "Select branches to delete"
    echo "Up/Down: move  Space: toggle  Enter: confirm  q: cancel"
    echo "Current branch: $current_branch (protected)"
    echo "Selected: $selected_count"
    echo

    for ((i = start; i <= end; i++)); do
        if [ "${selected_flags[i]}" -eq 1 ]; then
            prefix="[x]"
        else
            prefix="[ ]"
        fi

        if [ "$i" -eq "$cursor" ]; then
            pointer=">"
        else
            pointer=" "
        fi

        printf '%s %s %-6s | %s\n' "$pointer" "$prefix" "${branch_types[i]}" "${branch_names[i]}"
    done

    if [ "$start" -gt 0 ] || [ "$end" -lt $((${#branches[@]} - 1)) ]; then
        echo
        echo "Showing $((start + 1))-$((end + 1)) of ${#branches[@]} branches"
    fi
}

toggle_selection() {
    if [ "${selected_flags[cursor]}" -eq 1 ]; then
        selected_flags[cursor]=0
        selected_count=$((selected_count - 1))
    else
        selected_flags[cursor]=1
        selected_count=$((selected_count + 1))
    fi
}

interactive_select() {
    local key

    saved_stty=$(stty -g)
    trap cleanup_terminal EXIT INT TERM
    stty -echo -icanon time 0 min 1
    tput civis 2>/dev/null || true

    while true; do
        draw_menu
        IFS= read -rsn1 key

        case "$key" in
            '')
                break
                ;;
            ' ')
                toggle_selection
                ;;
            'q'|'Q')
                echo
                echo "Selection cancelled" >&2
                exit 0
                ;;
            $'\x1b')
                IFS= read -rsn2 key || true
                case "$key" in
                    '[A')
                        if [ "$cursor" -gt 0 ]; then
                            cursor=$((cursor - 1))
                        fi
                        ;;
                    '[B')
                        if [ "$cursor" -lt $((${#branches[@]} - 1)) ]; then
                            cursor=$((cursor + 1))
                        fi
                        ;;
                esac
                ;;
        esac
    done

    cleanup_terminal
    trap - EXIT INT TERM
}

# Check if we're in a git repository
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "Error: Not in a git repository" >&2
    exit 1
fi

if git remote get-url origin > /dev/null 2>&1; then
    read -r -p "Prune origin before scanning branches? (y/N): " prune_origin
    if [[ "$prune_origin" =~ ^[Yy]$ ]]; then
        echo "Pruning origin..." >&2
        git remote prune origin
    fi
fi

# Get current branch to prevent accidental deletion
current_branch=$(git branch --show-current)

echo "Scanning branches..." >&2

# Get local branches (excluding current)
while IFS= read -r branch; do
    # Remove leading * and whitespace
    branch=$(echo "$branch" | sed 's/^[* ]*//')
    if [ -n "$branch" ] && [ "$branch" != "$current_branch" ]; then
        branches+=("LOCAL|$branch")
        branch_types+=("LOCAL")
        branch_names+=("$branch")
        selected_flags+=(0)
    fi
done < <(git branch 2>/dev/null)

# Get remote branches (excluding HEAD pointers)
while IFS= read -r branch; do
    # Remove leading whitespace
    branch=$(echo "$branch" | sed 's/^  *//')
    if [ -n "$branch" ]; then
        branches+=("REMOTE|$branch")
        branch_types+=("REMOTE")
        branch_names+=("$branch")
        selected_flags+=(0)
    fi
done < <(git branch -r 2>/dev/null | grep -v 'HEAD')

# Check if there are any branches to delete
if [ ${#branches[@]} -eq 0 ]; then
    echo "No branches available for deletion (current branch excluded)" >&2
    exit 0
fi

echo "" >&2

interactive_select

if [ "$selected_count" -eq 0 ]; then
    echo "No branches selected" >&2
    exit 0
fi

# Display selected branches
echo ""
echo "---------------------------------------------"
echo "Selected branches for deletion:"
echo "---------------------------------------------"

selected=()
local_count=0
remote_count=0

for ((i = 0; i < ${#branches[@]}; i++)); do
    if [ "${selected_flags[i]}" -eq 1 ]; then
        printf '%-6s | %s\n' "${branch_types[i]}" "${branch_names[i]}"
        selected+=("${branch_types[i]}|${branch_names[i]}")
        if [ "${branch_types[i]}" = "LOCAL" ]; then
            local_count=$((local_count + 1))
        else
            remote_count=$((remote_count + 1))
        fi
    fi
done

echo "---------------------------------------------"
echo ""

echo "Total: $local_count local, $remote_count remote"
echo ""

# Confirmation prompt
read -p "Delete these branches? (y/N): " confirmation

if [[ ! "$confirmation" =~ ^[Yy]$ ]]; then
    echo "Deletion cancelled"
    exit 0
fi

# Delete selected branches
echo ""
success_count=0
error_count=0

for line in "${selected[@]}"; do
    branch_type=${line%%|*}
    branch_name=${line#*|}

    if [ "$branch_type" = "LOCAL" ]; then
        echo "→ Deleting local branch: $branch_name"
        if git branch -D "$branch_name" 2>&1; then
            ((success_count++))
        else
            ((error_count++))
        fi
    elif [ "$branch_type" = "REMOTE" ]; then
        # Extract remote name and branch name
        remote=$(echo "$branch_name" | cut -d'/' -f1)
        remote_branch=$(echo "$branch_name" | cut -d'/' -f2-)
        echo "→ Deleting remote branch: $branch_name"
        if git push "$remote" --delete "$remote_branch" 2>&1; then
            ((success_count++))
        else
            ((error_count++))
        fi
    fi
done

echo ""
echo "---------------------------------------------"
echo "✓ Complete: $success_count deleted, $error_count failed"
echo "---------------------------------------------"
